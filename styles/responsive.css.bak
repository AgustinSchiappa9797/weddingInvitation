@media (max-width: 767px) {

    .gallery-editorial-head {
        flex-direction: column;
        align-items: flex-start;
    }

    .gallery-editorial-meta {
        justify-content: flex-start;
    }

    .gallery-hint-text {
        font-size: 0.86rem;
        margin-bottom: 14px;
    }

    .gallery-wrapper {
        margin-inline: -8px;
        padding-inline: 0;
    }

    .gallery-horizontal {
        --gallery-card-width: min(82vw, 360px);
        padding-inline: max(16px, calc((100% - var(--gallery-card-width)) / 2));
    }

    .gallery-nav-button {
        width: 42px;
        height: 42px;
    }

    .lightbox {
        grid-template-columns: 1fr;
        gap: 12px;
        padding: 18px;
    }

    .lightbox-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 2;
    }

    .lightbox-nav-prev {
        left: 12px;
    }

    .lightbox-nav-next {
        right: 12px;
    }

    .lightbox-image {
        max-width: 100%;
        max-height: 72vh;
    }

    .lightbox-caption {
        font-size: 0.88rem;
        padding: 10px 14px;
    }
    .bg-overlay {
        background:
            radial-gradient(circle at top, rgba(255, 255, 255, 0.28), transparent 40%),
            linear-gradient(rgba(248, 243, 238, 0.42), rgba(248, 243, 238, 0.84)),
            var(--bg-photo) center 10% / cover no-repeat,
            linear-gradient(135deg, #f8f3ee 0%, #ece0d5 100%);
    }

    .screen-overlay {
        background:
            linear-gradient(rgba(248, 243, 238, 0.76), rgba(248, 243, 238, 0.9)),
            var(--bg-photo) center 10% / cover no-repeat,
            linear-gradient(135deg, #f8f3ee 0%, #ece0d5 100%);
    }

    .hero {
        padding: 22px 0 16px;
    }

    .hero-card,
    .card,
    .screen-card {
        padding-left: 20px;
        padding-right: 20px;
    }

    .hero-card {
        padding-top: 34px;
    }

    .hero-monogram {
        width: 64px;
        height: 64px;
        font-size: 1.35rem;
    }

    .title {
        max-width: 11ch;
        font-size: clamp(2.8rem, 10vw, 4.2rem);
    }

    .subtitle {
        font-size: 0.98rem;
        margin-bottom: 18px;
    }

    .hero-intro-note {
        padding: 12px 14px;
        font-size: 0.94rem;
    }

    .guest-box {
        padding: 18px 16px 16px;
        margin-bottom: 14px;
    }

    .hero-status-pill {
        width: 100%;
        margin-bottom: 14px;
    }

    .hero-highlights {
        grid-template-columns: 1fr;
        gap: 10px;
        margin-top: 0;
    }

    .hero-highlight-card {
        padding: 16px;
    }

    .hero-actions-split {
        flex-direction: column;
        gap: 10px;
    }

    .btn {
        width: 100%;
        text-align: center;
    }

    .countdown {
        grid-template-columns: repeat(2, minmax(90px, 1fr));
    }

    .screen-title {
        font-size: clamp(2rem, 8vw, 3rem);
    }

    .hub-nav {
        position: sticky;
        top: 8px;
        display: flex;
        align-items: stretch;
        justify-content: flex-start;
        gap: 10px;
        width: 100%;
        margin: 0 auto 16px;
        padding: 10px 36px 10px 10px;
        overflow-x: auto;
        overflow-y: hidden;
        flex-wrap: nowrap;
        scroll-snap-type: x proximity;
        scrollbar-width: none;
        border-radius: 20px;
    }

    .hub-nav::-webkit-scrollbar {
        display: none;
    }

    .hub-nav::before,
    .hub-nav::after {
        content: "";
        position: sticky;
        top: 0;
        width: 18px;
        flex: 0 0 18px;
        pointer-events: none;
        z-index: 2;
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .hub-nav::before {
        left: -10px;
        margin-right: -18px;
        background: linear-gradient(90deg, rgba(248, 243, 238, 0.92), rgba(248, 243, 238, 0));
    }

    .hub-nav::after {
        right: -26px;
        margin-left: -18px;
        background: linear-gradient(270deg, rgba(248, 243, 238, 0.92), rgba(248, 243, 238, 0));
    }

    .hub-tab {
        flex: 0 0 auto;
        flex-direction: row;
        align-items: center;
        justify-content: flex-start;
        text-align: left;
        gap: 8px;
        min-width: max-content;
        min-height: 52px;
        padding: 10px 14px;
        border-radius: 16px;
        scroll-snap-align: center;
    }

    .hub-tab-icon {
        width: 28px;
        height: 28px;
        border-radius: 9px;
        font-size: 0.9rem;
    }

    .hub-tab-label {
        font-size: 0.82rem;
        line-height: 1.15;
        text-align: left;
        white-space: nowrap;
    }

    .confirmation-progress,
    .access-quick-facts,
    .gift-bank-structured {
        grid-template-columns: 1fr;
    }

    .confirmation-summary-header,
    .confirmation-summary-row {
        display: grid;
        gap: 4px;
        justify-content: stretch;
    }

    .confirmation-summary-value {
        text-align: left;
    }

    .confirmation-actions {
        justify-content: stretch;
    }

    .choice-card {
        padding: 14px 15px;
    }

    .access-hero-card,
    .gift-data-header {
        grid-template-columns: 1fr;
        display: grid;
        align-items: stretch;
    }

    .access-hero-actions,
    .gift-actions {
        width: 100%;
    }

    .gift-actions .btn,
    .access-hero-actions .btn {
        width: 100%;
    }

    .mobile-sticky-rsvp {
        display: flex;
    }

    body {
        padding-bottom: 104px;
    }
}

@media (max-width: 420px) {
    .hub-nav {
        width: 100%;
        top: 6px;
        padding-right: 26px;
    }

    .content-panel {
        padding: 22px 20px;
    }

    .timeline-item {
        grid-template-columns: 1fr;
        gap: 6px;
    }
}

@media (min-width: 768px) {
    .hero-card {
        padding: 56px 42px 34px;
    }

    .content-panel {
        min-height: 420px;
        padding: 34px;
    }

    .panel-grid {
        grid-template-columns: 1fr 1fr;
    }

    .gallery-horizontal {
        grid-auto-columns: minmax(280px, 36%);
    }

    .gallery-item img,
    .gallery-horizontal img {
        height: 320px;
    }
}


@media (max-width: 859px) {
    .details-grid {
        grid-template-columns: 1fr;
    }

    .details-main-header,
    .access-hero-card {
        align-items: stretch;
    }

    .access-hero-card {
        flex-direction: column;
    }

    .access-hero-actions-group .btn,
    .details-side-card .btn {
        width: 100%;
    }
}


@media (max-width: 720px) {
    .playlist-header-card {
        flex-direction: column;
        align-items: stretch;
    }

    .playlist-embed {
        min-height: 352px;
    }
}


@media (max-width: 767px) {
    .cinematic-card {
        padding-top: 40px;
        padding-bottom: 30px;
    }

    .cinematic-monogram {
        width: 78px;
        height: 78px;
        margin-bottom: 14px;
        font-size: 1.6rem;
    }

    .cinematic-lead {
        font-size: 0.98rem;
        line-height: 1.65;
    }

    .cinematic-progress-text {
        font-size: 0.84rem;
        letter-spacing: 0.08em;
    }
}


@media (max-width: 720px) {
    .section {
        padding: 68px 0;
    }

    .footer {
        padding: 28px 0 124px;
    }

    .footer-shell {
        padding: 20px 18px 0;
    }

    .music-toggle {
        right: 14px;
        bottom: max(78px, calc(env(safe-area-inset-bottom) + 78px));
        padding: 11px 16px;
        min-height: 48px;
        max-width: calc(100vw - 28px);
        width: min(100%, 320px);
        gap: 10px;
    }

    body.has-sticky-rsvp .music-toggle {
        bottom: calc(max(78px, env(safe-area-inset-bottom) + 78px) + 84px);
    }

    .music-toggle__text {
        font-size: 0.9rem;
    }

    .music-toggle__hint {
        font-size: 0.7rem;
    }
}

@media (max-width: 420px) {
    .music-toggle {
        gap: 8px;
        padding: 11px 14px;
    }

    .music-toggle__copy {
        min-width: 0;
    }

    .music-toggle__text {
        max-width: 18ch;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .music-toggle__hint {
        max-width: 18ch;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
}
